NODE_ENV=production
PORT=3000

# MySQL Database (use Hostinger's database credentials from hPanel → Databases)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=plainchat

# JWT (generate a long random string)
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
